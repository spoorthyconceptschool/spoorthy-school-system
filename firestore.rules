rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      let role = request.auth.token.role != null 
        ? request.auth.token.role 
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
           ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           : null);
      return role;
    }

    function getSchoolId() {
      let uDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      
      return request.auth.token.branchId != null ? request.auth.token.branchId :
             (request.auth.token.schoolId != null ? request.auth.token.schoolId : 
             (exists(uDoc) && get(uDoc).data.branchId != null ? get(uDoc).data.branchId :
             (exists(uDoc) && get(uDoc).data.role == 'TEACHER' && get(uDoc).data.schoolId != null && exists(/databases/$(database)/documents/teachers/$(get(uDoc).data.schoolId)) ? get(/databases/$(database)/documents/teachers/$(get(uDoc).data.schoolId)).data.branchId :
             (exists(uDoc) && get(uDoc).data.role == 'STUDENT' && get(uDoc).data.schoolId != null && exists(/databases/$(database)/documents/students/$(get(uDoc).data.schoolId)) ? get(/databases/$(database)/documents/students/$(get(uDoc).data.schoolId)).data.branchId :
             (exists(uDoc) ? get(uDoc).data.schoolId : 'global')))));
    }
    
    function isSuperAdmin() {
      let r = getRole();
      return isSignedIn() && (r == 'SUPER_ADMIN' || r == 'super_admin' || request.auth.token.email == 'praneeth743x@gmail.com' || request.auth.token.email == 'praneeth.r@example.com');
    }

    function isAdmin() {
      let r = getRole();
      return isSignedIn() && (r == 'ADMIN' || r == 'admin' || isSuperAdmin());
    }

    function isManager() {
      let r = getRole();
      return isSignedIn() && (r == 'MANAGER' || r == 'manager' || isAdmin());
    }

    function isTeacher() {
      let r = getRole();
      return isSignedIn() && (r == 'TEACHER' || r == 'teacher');
    }

    function isSameSchool(data) {
       // Super Admins bypass tenant checks. If missing schoolId and branchId, we assume it's global config.
       return isSuperAdmin() || 
              (!("schoolId" in data) && !("branchId" in data)) || 
              (data.schoolId == null && data.branchId == null) || 
              (data.schoolId == getSchoolId() || data.branchId == getSchoolId());
    }

    // --- COLLECTION RULES ---

    // Admin-only collections (Audit, Analytics)
    match /audit_logs/{log} { allow read, write: if isManager() && isSameSchool(resource.data); }
    match /analytics/{doc} { allow read, write: if isManager() && isSameSchool(resource.data); }
    
    // Counters
    match /counters/{id} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    
    // Core Config
    match /config/academic_years { allow read: if true; allow write: if isSuperAdmin(); }
    match /config/{doc} { allow read: if isSignedIn(); allow write: if isManager(); }
    match /settings/{doc} { allow read: if isSignedIn() && isSameSchool(resource.data); allow write: if isManager() && isSameSchool(resource.data); }
    // System Config & Global Setup
    match /branches/{branchId} { 
      allow read: if isSignedIn();
      allow write: if isSuperAdmin(); 
    }

    // Master Data (Public Read allowed for landing page/admissions)
    match /master_classes/{doc} { allow read: if true; allow write: if isSuperAdmin(); }
    match /master_sections/{doc} { allow read: if true; allow write: if isSuperAdmin(); }
    match /master_villages/{doc} { allow read: if true; allow write: if isSuperAdmin(); }
    match /master_subjects/{doc} { allow read: if true; allow write: if isSuperAdmin(); }
    match /master_staff_roles/{doc} { allow read: if true; allow write: if isSuperAdmin(); }
    match /master_class_sections/{doc} { 
      allow read: if true; 
      allow write: if isManager() && isSameSchool(resource == null ? request.resource.data : resource.data); 
    }
    // Branch-specific Master Data
    match /villages/{id} { allow read: if isSignedIn(); allow write: if isManager(); }
    match /classes/{id} { allow read: if isSignedIn(); allow write: if isManager(); }
    match /sections/{id} { allow read: if isSignedIn(); allow write: if isManager(); }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || (isManager() && isSameSchool(resource.data)));
      allow update: if isSignedIn() && (request.auth.uid == userId || (isManager() && isSameSchool(resource.data)));
      allow create, delete: if isAdmin() && (isSuperAdmin() || request.resource.data.schoolId == getSchoolId());
    }

    match /user_sessions/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isManager());
    }

    // Students & Teachers
    match /students/{studentId} {
      // Managers/admins can read any student (they are already scoped by branchId in the query)
      // Teachers/others must match school via isSameSchool
      // Users can always read their own student record
      allow read: if isSignedIn() && (request.auth.uid == studentId || isManager() || isSameSchool(resource.data));
      allow write: if isManager() && (isSuperAdmin() || request.resource.data.branchId == getSchoolId() || request.resource.data.schoolId == getSchoolId());
    }
    
    match /teachers/{teacherId} {
      allow read: if isSignedIn() && (request.auth.uid == teacherId || isManager() || isSameSchool(resource.data));
      allow write: if isManager() && (isSuperAdmin() || request.resource.data.branchId == getSchoolId() || request.resource.data.schoolId == getSchoolId());
    }

    match /student_change_requests/{id} {
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid && request.resource.data.schoolId == getSchoolId();
      allow read: if isSignedIn();
      allow update, delete: if isManager() && isSameSchool(resource.data);
    }

    // Academic & Operations
    match /exams/{id} {
      allow read: if isSignedIn() && (isManager() || isSameSchool(resource.data));
      allow write: if isManager() && (isSuperAdmin() || isSameSchool(resource == null ? request.resource.data : resource.data));
    }

    match /exam_syllabus/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isManager() || isTeacher());
    }


    match /exam_results/{id} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.studentId || 
        (request.auth.token.email != null && request.auth.token.email.split('@')[0].upper() == resource.data.studentId) ||
        (isSameSchool(resource.data) && (isManager() || isTeacher()))
      );
      allow write: if (isManager() || isTeacher()) && (resource == null || isSameSchool(resource.data));
    }

    match /homework/{id} {
      allow read: if isSignedIn() && (isManager() || isTeacher() || isSameSchool(resource.data));
      allow write: if (isManager() || isTeacher()) && (isSuperAdmin() || request.resource.data.schoolId == getSchoolId());
    }
    
    match /attendance/{id} {
      allow read: if isSignedIn() && (isManager() || isTeacher() || isSameSchool(resource.data));
      allow write: if isManager() && (isSuperAdmin() || isSameSchool(resource.data));
    }
    
    match /attendance_daily/{id} {
      allow read: if isSignedIn() && (isManager() || isTeacher() || resource == null || isSameSchool(resource.data));
      allow write: if isManager() && (resource == null || isSameSchool(resource.data));
    }
    
    match /student_fee_ledgers/{id} { 
      allow read: if isSignedIn() && (isManager() || resource == null || isSameSchool(resource.data));
      allow write: if isManager() && isSameSchool(resource == null ? request.resource.data : resource.data); 
    }

    match /payments/{id} { 
      allow read: if isSignedIn() && (isManager() || resource == null || isSameSchool(resource.data));
      allow write: if isManager() && isSameSchool(resource == null ? request.resource.data : resource.data); 
    }
    
    match /invoices/{id} { 
      allow read: if isSignedIn() && (isManager() || resource == null || isSameSchool(resource.data));
      allow write: if isManager() && isSameSchool(resource == null ? request.resource.data : resource.data); 
    }

    // Communication & Notices
    match /notices/{id} {
      allow read: if isSignedIn() && (isManager() || isTeacher() || isSameSchool(resource.data));
      allow write: if (isManager() || isTeacher()) && (isSuperAdmin() || request.resource.data.schoolId == getSchoolId());
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isManager() ||
        (isSameSchool(resource.data) && (
          resource.data.target == 'ALL' || 
          resource.data.target == 'ALL_STUDENTS' || 
          resource.data.target == 'ALL_FACULTY' || 
          resource.data.target == 'ALL_ADMINS' || 
          (resource.data.target.matches('^class_.*')) ||
          isTeacher()
        ))
      );
      allow write: if (isManager() || isTeacher()) && (resource == null || isSameSchool(resource.data));
    }

    // Leave Management
    match /student_leaves/{id} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid || 
        isManager() ||
        (isTeacher() && isSameSchool(resource.data))
      );
      allow create: if isSignedIn() && request.resource.data.schoolId == getSchoolId();
      allow update, delete: if isManager() && isSameSchool(resource.data);
    }

    match /leave_requests/{id} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid && request.resource.data.schoolId == getSchoolId();
      allow update, delete: if isManager() && isSameSchool(resource.data);
    }

    // Miscellaneous
    match /website_settings/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /search_index/{id} {
      allow read: if isSignedIn() && isSameSchool(resource.data);
      allow write: if isSuperAdmin();
    }

    match /coverage_tasks/{id} {
      allow read: if isSignedIn() && (isManager() || isTeacher());
      allow write: if isManager() && isSameSchool(resource.data);
    }

    match /substitutions/{id} {
      allow read: if isSignedIn() && (isManager() || isTeacher());
      allow write: if isManager() && isSameSchool(resource.data);
    }

    match /exam_syllabus/{id} {
      allow read: if isSignedIn();
      allow write: if isSameSchool(resource.data) && (isTeacher() || isManager());
    }

    match /timetable_entries/{id} {
      allow read: if isSignedIn() && (isManager() || isTeacher() || isSameSchool(resource.data));
      allow write: if isManager() && isSameSchool(resource.data);
    }

    match /timetable_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    match /class_timetables/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    match /custom_fees/{id} {
      allow read: if isSignedIn() && (isManager() || isSameSchool(resource == null ? request.resource.data : resource.data));
      allow write: if isManager() && isSameSchool(resource == null ? request.resource.data : resource.data);
    }

    match /staff/{id} {
      allow read: if isSignedIn() && (isManager() || isSameSchool(resource.data));
      allow write: if isManager() && isSameSchool(resource.data);
    }

    match /salary_payments/{id} {
      allow read: if isSignedIn() && (isManager() || isSameSchool(resource.data));
      allow write: if isManager() && isSameSchool(resource.data);
    }

    match /groups/{id} {
      allow read: if isSignedIn() && (isManager() || isTeacher() || isSameSchool(resource.data));
      allow write: if (isManager() || isTeacher()) && (resource == null || isSameSchool(resource.data));
    }

    // Holidays & Calendar Events
    match /holidays/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    match /calendar_events/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // Transport Routes
    match /transport_routes/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // Complete Catch-all safeguard
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
